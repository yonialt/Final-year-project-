# Server
AI_SERVICE_PORT=8000

# MySQL (production SRMS) — install driver: pip install pymysql
DATABASE_URL=mysql+pymysql://srms:password@localhost:3306/srms?charset=utf8mb4

# Local dev (uncomment to use SQLite instead)
# DATABASE_URL=sqlite:///./srms_ai.db

# Redis (6-hour market price cache)
REDIS_URL=redis://localhost:6379/0
MARKET_PRICE_CACHE_TTL=21600

# E-commerce REST API (optional — uses category fallback if unset)
MARKET_API_BASE_URL=
MARKET_API_KEY=
MARKET_API_SEARCH_PATH=/search
