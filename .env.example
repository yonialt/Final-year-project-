# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/auth_db?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
