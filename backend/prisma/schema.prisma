generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  mustChangePassword Boolean        @default(false)
  role          Role           @default(STAFF)
  department    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  damageReports DamageReport[]
  maintenances  Maintenance[]  @relation("TechnicianMaintenances")
  notifications Notification[]
  requests      Request[]

  @@map("users")
}

model Resource {
  id              String         @id @default(cuid())
  name            String
  type            String
  location        String
  ownerDepartment String?
  purchaseDate    DateTime
  purchasePrice   Float
  status          ResourceStatus @default(AVAILABLE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  damageReports   DamageReport[]
  maintenances    Maintenance[]
  requests        Request[]

  @@map("resources")
}

model Request {
  id              String        @id @default(cuid())
  userId          String
  resourceId      String?
  description     String
  resourceName    String?
  resourceType    String?
  urgency         Priority      @default(MEDIUM)
  reason          String?
  status          RequestStatus @default(PENDING)
  type            String
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  resource        Resource?     @relation(fields: [resourceId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@map("requests")
}

model DamageReport {
  id               String             @id @default(cuid())
  userId           String
  resourceId       String
  description      String
  location         String
  status           DamageReportStatus @default(PENDING)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  aiRecommendation AIRecommendation?
  resource         Resource           @relation(fields: [resourceId], references: [id])
  user             User               @relation(fields: [userId], references: [id])
  maintenance      Maintenance?

  @@map("damage_reports")
}

model Maintenance {
  id              String       @id @default(cuid())
  damageReportId  String       @unique
  resourceId      String
  technicianId    String
  damageLevel     Int?
  repairCost      Float?
  inspectionNotes String?
  inspectedAt     DateTime?
  newPrice        Float?
  age             Int?
  aiDecision      String?
  aiConfidence    Float?
  aiMethod        String?
  finalDecision   String?
  officerNotes    String?
  repairNotes     String?
  repairedAt      DateTime?
  status          String       @default("PENDING_INSPECTION")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  damageReport    DamageReport @relation(fields: [damageReportId], references: [id])
  resource        Resource     @relation(fields: [resourceId], references: [id])
  technician      User         @relation("TechnicianMaintenances", fields: [technicianId], references: [id])

  @@map("maintenance")
}

model AIRecommendation {
  id             String       @id @default(cuid())
  damageReportId String       @unique
  decision       String
  confidence     Float
  costRatio      Float?
  method         String?
  inputData      Json?
  metrics        Json?
  createdAt      DateTime     @default(now())
  damageReport   DamageReport @relation(fields: [damageReportId], references: [id])

  @@map("ai_recommendations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model PriceCatalog {
  id           String   @id @default(cuid())
  resourceType String   @unique
  repairCost   Float
  newPrice     Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("price_catalog")
}

enum Role {
  STAFF
  DEPARTMENT_HEAD
  ACADEMIC_DEAN
  RESOURCE_OFFICER
  TECHNICIAN
  ADMIN
}

enum ResourceStatus {
  AVAILABLE
  IN_USE
  DAMAGED
  DISPOSED
}

enum RequestStatus {
  PENDING
  APPROVED_BY_HEAD
  APPROVED_BY_DEAN
  APPROVED_BY_OFFICER
  REJECTED
  PROCURED
  COMPLETED
}

enum DamageReportStatus {
  PENDING
  FORWARDED_TO_OFFICER
  INSPECTION_ASSIGNED
  INSPECTED
  AI_RECOMMENDED
  REPAIR_ASSIGNED
  REPAIR_COMPLETED
  REPLACED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}
